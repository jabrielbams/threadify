# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # server-side only, NEVER expose to client

# Google Gemini — get from https://aistudio.google.com/app/apikey
# Server-side only — NEVER prefix with NEXT_PUBLIC_
GEMINI_API_KEY=AIza...

# App Config
NEXT_PUBLIC_APP_URL=https://threadify.id
NEXT_PUBLIC_PWA_NAME=Threadify

# Test Account (development only — remove in production)
# Set these to bypass real OTP for local testing
TEST_PHONE=+6281325332561
TEST_OTP=123456
